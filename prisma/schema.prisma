// Prisma schema for the Kandimillets Admin Portal authentication foundation.
// Phase 1 scope only: Better Auth core tables (User/Session/Account/Verification)
// plus the Role/isActive/lastLoginAt fields reserved by the agreed architecture.
// Do not add Sales Register, analytics, or audit-log models here — later phases.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

// Better Auth's canonical "user" model, extended with the admin-portal
// fields agreed in the architecture review (role, isActive, lastLoginAt).
model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Admin-portal fields (reserved by design, enforced starting Phase 2+)
  role        AdminRole @default(ADMIN)
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?

  sessions Session[]
  accounts Account[]

  @@map("user")
}

// Better Auth's canonical "session" model.
model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

// Better Auth's canonical "account" model. For email/password auth this
// stores the hashed password alongside a providerId of "credential".
model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

// Better Auth's canonical "verification" model — used for password-reset
// and email-verification tokens (OTP delivery itself is a later phase).
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}
