# ---------------------------------------------------------------------------
# Kandimillets Admin Portal — Phase 1 environment variables
# Copy this file to .env and fill in real values. Never commit .env.
# ---------------------------------------------------------------------------

# PostgreSQL connection string used by the running app and the seed script
# (regular queries). On Neon, use the POOLED connection string here.
DATABASE_URL="postgresql://user:password@host-pooler.neon.tech/dbname?sslmode=require"

# PostgreSQL connection string used ONLY by the Prisma CLI (migrate/db seed
# invocation). On Neon, use the DIRECT/UNPOOLED connection string here —
# Prisma Migrate's advisory locks and DDL are unreliable over a
# transaction-mode pooler. Falls back to DATABASE_URL if unset.
DATABASE_URL_UNPOOLED="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Better Auth signing/encryption secret. Generate with:
#   openssl rand -base64 32
# Required in production — Better Auth throws if unset.
BETTER_AUTH_SECRET=""

# Public URL of this deployment (used by Better Auth for callback/cookie
# scoping). Example: https://kandimillets.com
BETTER_AUTH_URL="http://localhost:3000"

# NOTE: no NEXT_PUBLIC_BETTER_AUTH_URL variable — the client-side auth SDK
# (src/lib/auth/auth-client.ts) omits `baseURL` entirely so Better Auth
# resolves it from window.location.origin at runtime. This is required
# because frontend and API are served by the same Next.js app; a
# NEXT_PUBLIC_ value would be baked into the client bundle at build time
# and would break on any deployment URL other than the one it was built
# against (e.g. Preview deployments).

# ---------------------------------------------------------------------------
# Seed script credentials (prisma/seed.ts) — the ONLY three admin accounts
# provisioned in Phase 1. There is no public sign-up route. Replace every
# placeholder below before running `npm run db:seed`.
# ---------------------------------------------------------------------------
SEED_SHAURYA_EMAIL="shaurya@example.com"
SEED_SHAURYA_PASSWORD="change-me-before-seeding"

SEED_FATHER_EMAIL="father@example.com"
SEED_FATHER_PASSWORD="change-me-before-seeding"

SEED_BUSINESS_EMAIL="business@example.com"
SEED_BUSINESS_PASSWORD="change-me-before-seeding"

# ---------------------------------------------------------------------------
# Existing public-site variable (unrelated to the admin portal) — unchanged.
# ---------------------------------------------------------------------------
GOOGLE_SHEETS_WEBHOOK_URL=""

# ---------------------------------------------------------------------------
# Authentication Hardening & Password Recovery — email delivery (Resend).
# Get an API key at https://resend.com. If unset, password-reset emails
# are logged server-side instead of sent — safe for local development,
# but reset links will only be visible in the server console, never in a
# real inbox. Required for production.
# ---------------------------------------------------------------------------
RESEND_API_KEY=""

# Must be a domain/sender you've verified with Resend. The default below
# only works for accounts still on Resend's own sandbox domain.
RESEND_FROM_EMAIL="Kandimillets Admin <onboarding@resend.dev>"
